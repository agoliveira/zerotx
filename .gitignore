# Go build artifacts
pi/daemon/bin/
pi/daemon/zerotxd
pi/daemon/*.test
pi/daemon/*.out
go.work
go.work.sum

# RP2040 build
rp2040/build/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Local config (don't commit private model files etc)
*.local.yml
*.local.yaml
/local/

# Telemetry / flight logs
/flights/

# Tarballs from earlier transfer workflow
*.tar.gz
*.tgz

# Private working notes (Claude session journal)
JOURNAL.md

# TTS voice models (downloaded by scripts/fetch-voices.sh, ~130MB)
/voices/

# Piper TTS binary distribution (downloaded locally)
/bin/

# Geo place-name databases (built by tools/build-geo.sh, ~30-50MB
# regional). Live data, not source. Build pipeline is in repo;
# the resulting .db files are not.
/geo/*.db

# Patch files generated by Claude during iteration (apply locally, don't commit)
*.patch

# Private session handover (Claude session bootstrap, not for repo)
HANDOVER.md

# Patch artefacts left behind when patch(1) fuzz-applies a hunk
# or fails: .orig is the pre-edit copy, .rej is the rejected hunk.
*.orig
*.rej
maptiles/

# Compiled binaries (built locally, not version-controlled)
/zerotx
/tools/maps/sat-download/sat-download
