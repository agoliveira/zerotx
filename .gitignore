# Go build artifacts
go.work
go.work.sum

# Firmware builds (CRSF on RP2040 via Pico SDK + CMake)
firmware/crsf/build/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Local config (don't commit private model files etc)
*.local.yml
*.local.yaml
/local/

# Telemetry / flight logs
/flights/

# Tarballs from earlier transfer workflow
*.tar.gz
*.tgz

# Private working notes (Claude session journal)
JOURNAL.md

# Compiled outputs: our binaries (daemon, tools, firmware artifacts)
# all land in /bin/ via scripts/build-*.sh.
/bin/

# Downloaded third-party tools and data (Piper TTS binary, ONNX voice
# models). Fetched by scripts/fetch-voices.sh and the operator's
# manual Piper install step from docs/BOOTSTRAP.md.
/third_party/

# Geo place-name databases (built by tools/build-geo.sh, ~30-50MB
# regional). Live data, not source. Build pipeline is in repo;
# the resulting .db files are not.
/geo/*.db

# Patch files generated by Claude during iteration (apply locally, don't commit)
*.patch

# Private session handover (Claude session bootstrap, not for repo)
HANDOVER.md

# Patch artefacts left behind when patch(1) fuzz-applies a hunk
# or fails: .orig is the pre-edit copy, .rej is the rejected hunk.
*.orig
*.rej
maptiles/

# Stray in-tree binaries from inline `go build` invocations. The
# canonical output location is /bin/ above; these patterns catch
# accidental local builds so they don't shadow the canonical artifacts.
/pi/daemon/bin/
/pi/daemon/zerotxd
/pi/daemon/*.test
/pi/daemon/*.out
/pi/daemon/cmd/*/zerotxd
/pi/daemon/cmd/*/disptest
/pi/daemon/cmd/*/geobuild
/pi/daemon/cmd/*/zerotx-axes
/pi/daemon/cmd/*/zerotx-inspect
/tools/zerotx-bench/zerotx-bench
/tools/zerotx-iohal-config/zerotx-iohal-config
/tools/zerotx-replay/zerotx-replay
/tools/maps/sat-download/sat-download
/zerotx

# Daemon runtime state (not source)
cache/
*.tmp
*.log

# PlatformIO build artifacts (firmware/io, firmware/tracker, etc.)
.pio/

# Python build artifacts (firmware/crsf/tools/, firmware/crsf/tests/)
__pycache__/
*.pyc
*.pyo
.venv/
venv/
