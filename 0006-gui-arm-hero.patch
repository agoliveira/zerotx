+// validateShortcut checks that a shortcut string is well-formed:
+// at least one modifier (ctrl/shift/alt/meta) and one non-modifier
+// key part. Returns {ok: bool, error?: string}.
+function validateShortcut(s) {
+  if (!s) return { ok: false, error: 'Shortcut is empty.' };
+  const parts = s.toLowerCase().split('+').map(p => p.trim()).filter(Boolean);
+  const mods = parts.filter(p => ['ctrl', 'shift', 'alt', 'meta', 'cmd'].includes(p));
+  const keys = parts.filter(p => !['ctrl', 'shift', 'alt', 'meta', 'cmd'].includes(p));
+  if (mods.length === 0) return { ok: false, error: 'Must include a modifier (Ctrl, Shift, or Alt).' };
+  if (keys.length !== 1) return { ok: false, error: 'Must include exactly one non-modifier key.' };
+  const key = keys[0];
+  if (key.length !== 1 || !/[a-z0-9]/.test(key)) {
+    return { ok: false, error: 'Key must be a single letter or digit (a-z, 0-9).' };
+  }
+  return { ok: true };
+}
