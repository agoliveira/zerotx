--- firmware/display/src/main.cpp
+++ firmware/display/src/main.cpp
@@ -629,80 +629,37 @@ void setup() {
   u8g2.setFontMode(1);              // transparent (background not erased)
   u8g2.setFontDirection(0);          // left-to-right
 
-  // Power-on self test. Visible confirmation that wiring, chaining,
-  // and library config are correct. Each stage holds long enough to
-  // see clearly. If any stage looks wrong you know what to check:
-  //   solid color phase wrong  -> R/G/B pin mapping or signal level
-  //   only half the surface    -> chain ribbon or PANELS_NUM
-  //   text wrong/upside-down   -> A/B/C/D pin mapping
-  //   nothing at all           -> power, ground, or library init
-  run_self_test();
+  // Identification banner. Brief visual confirmation that firmware
+  // and panel are alive at the version we expect, before the
+  // daemon takes over. The earlier stages of self-test (RGB
+  // surfaces, color bars, A/B half-labels, seam marker) lived
+  // here for bring-up; with the panel and chain order locked in,
+  // they're no longer earning their boot-time cost.
+  show_boot_banner();
 
   boot_ms = millis();
   send_ready();
   needs_redraw = true;
 }
 
-// run_self_test cycles through visible patterns to verify the panel
-// chain end-to-end. Runs once at boot. Total duration ~4 seconds.
-void run_self_test() {
+// show_boot_banner displays "ZEROTX <version>" briefly at boot so
+// the operator can see firmware loaded and panel power is up before
+// the daemon link is established. Held for ~800ms; the daemon's
+// first frame will overwrite it.
+void show_boot_banner() {
   if (!dma_display) return;
-
-  uint16_t red    = dma_display->color565(255, 0, 0);
-  uint16_t green  = dma_display->color565(0, 255, 0);
-  uint16_t blue   = dma_display->color565(0, 0, 255);
-  uint16_t white  = dma_display->color565(255, 255, 255);
-  uint16_t black  = dma_display->color565(0, 0, 0);
-
-  // Stage 1-3: solid colors, full surface. Each panel should turn
-  // the named color completely.
-  dma_display->fillScreen(red);    delay(700);
-  dma_display->fillScreen(green);  delay(700);
-  dma_display->fillScreen(blue);   delay(700);
-
-  // Stage 4: color bars. Vertical stripes RGBW. Confirms pixel
-  // addressing is correct across the full 128px width and that the
-  // chain is wired in the expected order (panel A on the left,
-  // panel B on the right).
-  dma_display->fillScreen(black);
-  int bar_w = LOGICAL_WIDTH / 4; // 32 px each
-  dma_display->fillRect(bar_w * 0, 0, bar_w, LOGICAL_HEIGHT, red);
-  dma_display->fillRect(bar_w * 1, 0, bar_w, LOGICAL_HEIGHT, green);
-  dma_display->fillRect(bar_w * 2, 0, bar_w, LOGICAL_HEIGHT, blue);
-  dma_display->fillRect(bar_w * 3, 0, bar_w, LOGICAL_HEIGHT, white);
-  delay(900);
-
-  // Stage 5: panel boundary marker. Draws a vertical line exactly
-  // at the seam between panels A and B (x=64). If the seam isn't
-  // where you expect it, chain order is wrong.
-  dma_display->fillScreen(black);
-  dma_display->drawFastVLine(PANEL_WIDTH, 0, LOGICAL_HEIGHT, white);
-  // Label each half so you can tell A from B at a glance.
-  dma_display->setTextColor(red);
-  dma_display->setTextSize(1);
-  dma_display->setCursor(2, 12);
-  dma_display->print("A");
-  dma_display->setTextColor(green);
-  dma_display->setCursor(PANEL_WIDTH + 2, 12);
-  dma_display->print("B");
-  delay(900);
-
-  // Stage 6: identification banner. Uses VCR-OSD font for that
-  // CRT-overlay aesthetic that previews the in-flight visual.
-  dma_display->fillScreen(black);
+  dma_display->clearScreen();
   u8g2.setFont(FONT_TEXT);
   u8g2.setForegroundColor(dma_display->color565(0, 200, 160));
   int w_zerotx = u8g2.getUTF8Width("ZEROTX");
   u8g2.setCursor((LOGICAL_WIDTH - w_zerotx) / 2, 18);
   u8g2.print("ZEROTX");
-  // Version below in dim cyan, small font.
   u8g2.setFont(FONT_SMALL);
   u8g2.setForegroundColor(dma_display->color565(0, 100, 80));
   int w_ver = u8g2.getUTF8Width(FW_VERSION);
   u8g2.setCursor((LOGICAL_WIDTH - w_ver) / 2, 30);
   u8g2.print(FW_VERSION);
-  delay(1500);
-
+  delay(800);
   dma_display->clearScreen();
 }
 
