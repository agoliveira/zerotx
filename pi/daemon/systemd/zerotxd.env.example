# ZeroTX daemon environment file.
#
# Copy this to ~/.config/zerotx/zerotxd.env and edit for your machine.
# The systemd unit (~/.config/systemd/user/zerotxd.service) reads
# this file at start time. After editing, restart the daemon:
#
#     systemctl --user restart zerotxd
#
# Variables are read by systemd's EnvironmentFile, which means simple
# KEY=VALUE lines, no shell expansion, no quotes interpreted as code.
# Substitute literal paths; ~ does NOT expand here.

# === Required ===

# API server bind address. 127.0.0.1 keeps the API local to the Pi;
# use 0.0.0.0 only if you actually need remote access.
API_ADDR=127.0.0.1:8080

# Model file. Use the absolute path; ~ won't expand.
MODEL=/home/USER/zerotx/configs/big_talon_zerotx.yml

# Joystick name as reported by the system. The daemon matches by
# substring, so "Thrustmaster" is enough for any T.Flight HOTAS X.
JOYSTICK_NAME=Thrustmaster

# Piper TTS binary. Manual install per docs/BOOTSTRAP.md;
# scripts/fetch-voices.sh fetches the voice models that go alongside.
PIPER_BINARY=/home/USER/zerotx/third_party/piper/piper

# Web GUI assets directory.
WEB_DIR=/home/USER/zerotx/pi/daemon/web

# Voice language for narration. "en" or "pt".
SOUNDS_LANG=pt

# === Optional ===
#
# Anything beyond the required set goes here as a single
# space-separated string. systemd splits on whitespace for argv.
# Comment out or set EXTRA_FLAGS="" to skip.
#
# Common additions:
#   -vfd-port log
#       Run the diagnostic VFD firehose without hardware (logs to
#       journal). Use a serial path like /dev/ttyACM2 for real VFD.
#   -geo-db /home/USER/zerotx/geo/places-brazil.db
#       Enrich post-flight narration with offline place names.
#   -mwp-tee-addr 127.0.0.1:5761
#       CRSF tee for mwp. Default value matches this; set to empty
#       (-mwp-tee-addr "") to disable.
#   -no-recordings
#       Skip flight recording (useful for bench-only sessions).
#   -no-audio
#       Mute everything (alarms + TTS). Bench testing aid.
#
# Example:
EXTRA_FLAGS="-geo-db /home/USER/zerotx/geo/places-brazil.db"
