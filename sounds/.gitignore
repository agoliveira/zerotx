# Generated audio banks - not committed.
en/
pt/
*/*.mp3
*/*.wav
*/*.ogg
!overrides/**/*.mp3
!overrides/**/*.wav
!overrides/**/*.ogg

# Personal configuration - voice IDs, cloned voices, custom banks.
# This is gitignored by design; see personal.yml.example for the
# structure and copy/edit to create your own.
personal.yml

# Override directory: committed contents are honoured (see exceptions
# above for audio extensions), but the directory's own structure stays
# minimal in fresh clones.
overrides/*
!overrides/.gitkeep
!overrides/README.md
!overrides/en/
!overrides/pt/
